# Server
PORT=3000
CORS_ORIGIN=*

# STEP 9: max edits per user per second (default 5)
# MAX_EDITS_PER_SECOND=5
# STEP 10: auto-snapshot interval in minutes (default 5)
# AUTO_SNAPSHOT_INTERVAL_MINUTES=5

# Supabase (Phase 5 + STEP 1 auth)
# Get from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Required for creating users after OTP verify: Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=
# OTP email (STEP 1) — Gmail with App Password
# Use your Gmail and create an App Password: Google Account → Security → 2-Step Verification → App passwords
EMAIL_USER=
EMAIL_PASSWORD=

